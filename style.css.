* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background: #ffffff;
    color: #000000;
    transition: 0.4s;
}

/* الثيمات */

body.white-theme {
    background: #ffffff;
    color: #000000;
}

body.black-theme {
    background: #111111;
    color: #ffffff;
}

body.black-theme header,
body.black-theme .product-card,
body.black-theme .cart-sidebar,
body.black-theme .order-modal,
body.black-theme .theme-selector {
    background: #1e1e1e;
    color: white;
}

body.black-theme h1,
body.black-theme h2,
body.black-theme h3,
body.black-theme p,
body.black-theme span {
    color: white;
}

/* RGB */

body.rgb-theme {
    animation: rgbBackground 8s infinite linear;
    color: white;
}

@keyframes rgbBackground {
    0% { background: red; }
    20% { background: orange; }
    40% { background: yellowgreen; }
    60% { background: blue; }
    80% { background: purple; }
    100% { background: red; }
}

/* Theme Selector */

.theme-selector {
    text-align: center;
    padding: 20px;
}

.theme-buttons {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
}

.theme-buttons button {
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
}

/* Header */

header {
    background: black;
    color: white;
    padding: 20px;
    text-align: center;
}

.logo {
    font-size: 32px;
    font-weight: bold;
    margin-bottom: 15px;
}

nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
}

nav button,
.whatsapp-btn {
    padding: 10px 15px;
    border: none;
    border-radius: 10px;
    text-decoration: none;
    cursor: pointer;
    font-weight: bold;
}

.whatsapp-btn {
    background: green;
    color: white;
}

/* Hero */

.hero {
    text-align: center;
    padding: 40px 20px;
}

.hero h1 {
    margin-bottom: 10px;
}

/* Products */

.products {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
    gap: 20px;
    padding: 20px;
}

.product-card {
    background: white;
    border-radius: 15px;
    padding: 15px;
    text-align: center;
    box-shadow: 0 0 10px rgba(0,0,0,.1);
}

.product-card img {
    width: 100%;
    height: 220px;
    object-fit: contain;
}

.product-card h3 {
    margin: 10px 0;
}

.product-card p {
    font-size: 18px;
    font-weight: bold;
}

.product-buttons {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.product-buttons button {
    flex: 1;
    border: none;
    padding: 10px;
    border-radius: 8px;
    cursor: pointer;
}

.add-btn {
    background: #28a745;
    color: white;
}

.order-btn {
    background: #007bff;
    color: white;
}

/* Cart */

.cart-button {
    position: relative;
}

#cart-count {
    background: red;
    color: white;
    border-radius: 50%;
    padding: 2px 8px;
}

.cart-sidebar {
    position: fixed;
    top: 0;
    right: -400px;
    width: 350px;
    height: 100%;
    background: white;
    padding: 20px;
    overflow-y: auto;
    transition: .4s;
    z-index: 999;
}

.cart-sidebar.active {
    right: 0;
}

.cart-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
}

.cart-item {
    margin-bottom: 15px;
    border-bottom: 1px solid #ddd;
    padding-bottom: 10px;
}

.qty-controls {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 5px;
}

.qty-controls button {
    width: 30px;
    height: 30px;
    border: none;
    cursor: pointer;
    border-radius: 5px;
    font-size: 18px;
}

.cart-total {
    margin-top: 20px;
    font-size: 20px;
    font-weight: bold;
}

.checkout-btn {
    width: 100%;
    margin-top: 15px;
    padding: 12px;
    background: green;
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
}

/* Overlay */

.overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.5);
    display: none;
    z-index: 998;
}

.overlay.active {
    display: block;
}

/* Order Modal */

.order-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    background: white;
    width: 90%;
    max-width: 500px;
    padding: 20px;
    border-radius: 15px;
    display: none;
    z-index: 1000;
}

.order-modal.active {
    display: block;
}

.order-modal input,
.order-modal select {
    width: 100%;
    margin-top: 10px;
    padding: 10px;
}

.payment-box {
    margin-top: 15px;
    line-height: 2;
}

.payment-note {
    background: #fff3cd;
    color: #856404;
    border: 1px solid #ffeeba;
    padding: 10px;
    border-radius: 10px;
    margin-bottom: 10px;
    display: none;
    font-size: 14px;
}

.order-modal button {
    width: 100%;
    margin-top: 15px;
    padding: 12px;
    border: none;
    background: #007bff;
    color: white;
    border-radius: 10px;
    cursor: pointer;
}
